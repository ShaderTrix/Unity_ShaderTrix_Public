[numthreads(512,1,1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    if (id.x >= (uint)_AgentCount) return;

    float3 p = _AgentsBuffer[id.x].position;
    float3 d = p - _CameraPos;

    if (dot(d, d) > _MaxVertexDistance * _MaxVertexDistance) return;
    float sqrDist = dot(d, d);
    
    //     float4 clip = mul(_VPMatrix, float4(p,1));
    //     if (abs(clip.w) < 1e-6) return;            // avoid divide by zero
    // float3 ndc = clip.xyz / clip.w;            // -1..1
    // // behind camera if ndc.z < -1 or ndc.z > 1 depending on projection, but clip.w sign issues handled by abs above
    // if (ndc.x < -1 || ndc.x > 1 || ndc.y < -1 || ndc.y > 1 || ndc.z < -1 || ndc.z > 1) return;
    
    bool isVisible = true;
    if (!isInFrontOfPlane(_ViewFrustumPlanes[5], p))
        isVisible = false; //early break check    

    [unroll]
    for (int i = 0; i < 5; i++)
    {
        if (!isInFrontOfPlane(_ViewFrustumPlanes[i], p))
        {
            isVisible = false;
            break;
        }        
    }
    // if(!isOccluded(p)) 
    //     isVisible = false;
    if(!isOccluded_HiZ(p,0.25f,_VPMatrix,float2(_HiZTextureSize, _HiZTextureSize),_HiZMipCount,_DepthBias))
        isVisible = false;

    if(!isVisible)return;  
    if (sqrDist < _LodDist01) _AppendLOD0.Append(id.x);
    else if (sqrDist < _LodDist02) _AppendLOD1.Append(id.x);
    else _AppendLOD2.Append(id.x);
}
